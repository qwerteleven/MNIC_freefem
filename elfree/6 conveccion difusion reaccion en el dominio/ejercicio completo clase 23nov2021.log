 Load: lg_fem lg_mesh lg_mesh3 eigenvalue
    1 : /* PROBLEMA CONVECCION DIFUSION Y EVOLUTIVO EN EL TIEMPO HACIA LA SOLUCION ESTACIONARIA
    2 :
    3 : aqui el vector velocidad es dato, luego consideramos teoria y aplicaciones con ecuaciones de Navier Stokes para
calculo de velocidades */
    4 :
    5 :
    6 :
    7 : int n=100;
    8 : int m=0;  // para contar iteraciones luego
    9 :
   10 : border a(t=20,0) {x=-12;y=t;label=1;}
   11 : border b(t=-12,0) {x=t;y=0;label=2;}
   12 : border c(t=0,20) {x=t; y=t ;label=4;}
   13 : border d(t=20,-12) {x=t;y=20;label=3;}
   14 :
   15 : mesh malla = buildmesh(a(n)+b(n)+c(n)+d(n));
   16 : plot (malla, wait=1);
   17 :
   18 :
   19 : real dt=0.5,t=0;
   20 : real alpha=1/dt;
   21 :
   22 : fespace Vh(malla,P1);
   23 : Vh T,v,u1,u2,k,Toldt;
   24 :
   25 :
   26 : // T es la incognita u
   27 :
   28 : // r e la cte del termino de reaccion
   29 :
   30 : real r=0.2;
   31 :
   32 : u1=2;// Wx
   33 : u2=0; //Wy
   34 : k=5;
   35 :
   36 : Toldt=100;
   37 :
   38 : plot([u1,u2],wait=1);
   39 :
   40 : problem convecdif (T,v)=
   41 :
   42 : int2d (malla)  ( T*v/dt)  - int2d(malla)(Toldt*v/dt) // derivada parcial resp tiempo
   43 :
   44 : +int2d(malla) (u1*dx(T)*v+u2*dy(T)*v) // termino nuevo de conveccion
   45 :
   46 : +int2d (malla) (k*dx(T)*dx(v)+k*dy(T)*dy(v) ) // metodo de Euler en estos terminos difusivos
   47 :
   48 : -int1d(malla,2)(10*k*v) -int1d(malla,3)(10*k*v)
   49 :
   50 : +int2d(malla) (r*T*v)
   51 :
   52 :  + on (1,T=100)
   53 :  + on (4,T=200);
   54 :
   55 :
   56 : real Tmax=600;
   57 :
   58 :
   59 : for(t=0;t<Tmax;t+=dt)
   60 :
   61 : {
   62 :
   63 : m=m+1;
   64 :
   65 : Toldt=T;
   66 : convecdif;
   67 :
   68 : if ( !(m % 10))             //cada multiplo de 10 imprime el plot de la linea siguiente
   69 : plot(T,cmm=" t="+t + ", min=" + T[].min + ", max=" + T[].max,value=1);
   70 :
   71 : }
   72 :
