-- FreeFem++ v4.1 (Sat, Nov 13, 2021  7:40:01 PM - git v4.10)
   file : C:\Users\admin\Desktop\elfree\EDP2\12 NAVIER STOKES FLUJO INCOMPRESIBLE\8 Wind profile 1 and airflow around two buidings.edp
 Load: lg_fem lg_mesh lg_mesh3 eigenvalue
    1 : /*
    2 : Data here to obtain wind profile are
    3 :         SOLAR RADIATION 0 w/m2  (night time)
    4 :         Wind at 10 meter on the ground, terrain = 4,0 m/s
    5 :
    6 : then running with matlab the file perfil_viento.m we obtain
    7 :          u* = u friction= friction velocity = 1.0539
    8 :        L = -704.9502 Monin-Obukhov length
    9 :
   10 : k = 0.41  Von Karman constant, sometimes is used 0.4
   11 :
   12 :  u ( z ) = (ufriction/k)*(log(z/z0)+(4.7/L)*(z-z0))
   13 :
   14 : Pasquill stability class : "Atmósfera ligeramente estable"
   15 :
   16 : Longitud de Monin-Obukhov:
   17 :
   18 : L = 1/(a + b*log10(z0))
   19 : L = 1/(0.0040-0.0180*log10(2.000000))
   20 : L = -704.950199  Monin-Obukhov length
   21 :
   22 : */
   23 :
   24 : real L = -704.9502; // Monin-Obukhov length
   25 : real ufriction= 1.0539;
   26 :
   27 : real zo= 2; // roughness height , data
   28 :
   29 :
   30 : border a(t=-20,10){ x=t; y=2; label=2;}
   31 :
   32 : /* it is right to choise lower level of the simulation
   33 : at vertical = y= zo */
   34 :
   35 : border b(t=2,10){ x=10; y=t; label=2;}
   36 : border c(t=10,30){ x=t; y=10; label=2;}
   37 : border d(t=10,2){ x=30; y=t; label=2;}
   38 : border e(t=30,50){ x=t; y=2; label=2;}
   39 :
   40 : // second facade
   41 : border f(t=2,5) { x=50; y=t; label=2;}
   42 : border g(t=50,70){ x=t; y=5; label=2;}
   43 : border h(t=5,2){ x=70; y=t; label=2;}
   44 :
   45 : border k(t=70,120) { x=t; y=2; label=2;}
   46 : border l(t=2,30) { x=120; y=t; label=3;}  // outlet air
   47 : border m(t=120,-20) {x=t; y=30; label=2;}
   48 :
   49 : border r(t=30,2) {x=-20; y=t; label=1;}     // inlet air
   50 :
   51 :
   52 : int n=20;
   53 : mesh Th= buildmesh(a(n)+b(n)+c(n*3)+d(n)+e(4*n)+f(n*3)+g(n*3)+h(n*3)+k(4*n)+ l(n)+ m(4*n)+ r(4*n)) ;
   54 :
   55 : plot(Th,wait=1);
   56 :
   57 :
   58 : // aprox tmax = 140 / 7 = 20 seconds
   59 :
   60 : real tmax=20;
   61 :
   62 : real nu = 0.000016; // air cinematic viscosity  m2/s for 30 şC,
   63 :
   64 : real dt = 0.01;  // a veces es necesario considerar 0.001
   65 :
   66 : real t;
   67 : int iter;
   68 : iter=0;
   69 :
   70 : /*
   71 :
   72 : Chorin algorithm improved  to solve Navier Stokes
   73 :
   74 : ***********************************************************  */
   75 :
   76 : fespace Vh(Th,P1);
   77 : Vh w,u, v =0, p = 0, q=0; // w funcion test elementos finitos
   78 : real area= int2d(Th)(1.);
 *** Warning  The identifier area hide a Global identifier
 
   79 :
   80 :
   81 : for(t=0;t<tmax;t+=dt)
   82 : {
   83 :         iter=iter+1;
   84 :         Vh uold = u, vold = v, pold=p;
   85 :         Vh f=convect([uold,vold],-dt,uold), g=convect([uold,vold],-dt,vold);
   86 :
   87 :         solve pb4u(u,w,init=n,solver=LU)
   88 :         = int2d(Th)(u*w/dt +nu*(dx(u)*dx(w)+dy(u)*dy(w)))
   89 :         - int2d(Th)((f/dt-dx(p))*w)
   90 :         + on(1,u = (ufriction/.41)*log(y/zo)+(4.7*(y-zo)/L))+
   91 :         on(2,u = 0)+ on(3,u=f);
   92 : // label 3 es contorno de salida del aire
   93 :
   94 :
   95 :         solve pb4v(v,w,init=n,solver=LU)
   96 :         = int2d(Th)(v*w/dt +nu*(dx(v)*dx(w)+dy(v)*dy(w)))
   97 :         - int2d(Th)((g/dt-dy(p))*w)
   98 :         + on(1,2,v = 0);
   99 :
  100 :         real meandiv = int2d(Th)(dx(u)+dy(v))/area;
  101 :
  102 :         solve pb4p(q,w,init=n,solver=LU)
  103 :         = int2d(Th)(dx(q)*dx(w)+dy(q)*dy(w))
  104 :         - int2d(Th)((dx(u)+ dy(v)-meandiv)*w/dt)
  105 :         + on(3,q=0);
  106 :
  107 :         real meanpq = int2d(Th)(pold - q)/area;
  108 :
  109 :         if(iter%10)// plotea cada 10 iteraciones
  110 :
  111 :         plot([u,v],cmm=" tiempo ="+t,value=1);
  112 :         p = pold-q-meanpq;
  113 :         u = u + dx(q)*dt;
  114 :         v = v + dy(q)*dt;
  115 :
  116 : }
  117 :
  118 : // ************* end of Chorin algorithm************************
