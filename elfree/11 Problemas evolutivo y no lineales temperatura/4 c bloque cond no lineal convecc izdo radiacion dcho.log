  106 : // Temperatura en kelvin
  107 :
  108 :
  109 : problem calor (u,v) =
  110 : int2d(malla)(epsilon*u*v)+
  111 : int2d (malla)(a*u*v/dt)-int2d(malla)(a*uoldt*v/dt)
  112 :
  113 : +int2d(malla)(kk*dx(u)*dx(v)+kk*dy(u)*dy(v))
  114 :
  115 : + int1d(malla,2) (sigma*emisivity*B*u*v)
  116 : - int1d(malla,2) (sigma*emisivity*B*uf*v)
  117 :
  118 : + int1d(malla,1) (hc*u*v) - int1d(malla,1) (hc*u0*v);
  119 :
  120 : //+ on(1,u=u0);
  121 :
  122 :
  123 : uoldt=u0;
  124 :
  125 : for(real t=0;t<T;t+=dt) // bucle de iteraciones en el tiempo t desde t=0 hasta t=T
  126 :
  127 : {
  128 :
  129 : uold=u0;
