   67 : Vh u,v,uold, uoldt,uu,kk,B,uc,error;
   68 :
   69 : /* despues haremos :
   70 :  kk = k1(u)*(region==material1)
   71 :       + k2(u)*(region==aire1)
   72 :       + k2(u)*(region==aire2)
   73 :       + k2(u)*(region==aire3);
   74 :
   75 :  k1 y k2 se evaluaran en u calculada en la iteracion anterior que se denomina uold
