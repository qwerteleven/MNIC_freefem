   77 :
   78 : // Conductividad termica del picon-hormigon: aproximadamente 0.38 a 20ºC y 0.5 a 700 ºC
   79 :
   80 : func real k1(real T) { return (0.3764705 + 0.00017647059*T);}
   81 :
   82 : func real k2(real T)
   83 : { return (0.0244706 +(0.00006)*(T-273.15));}
   84 :
   85 : real sigma = 5.6704*1e-8; //Constante de Stefan-Boltzmann [W/m2.K4]
   86 : real emisivity = 0.8;
   87 :
   88 : real uf = 700 + 273.15; //Temperatura UR del foco caliente [ÂºK]
   89 : real u0 = 20 + 273.15;  //Condicion Dirichlet del contorno exterior (cuadrado) [ÂºK]
   90 :
   91 : //  luego haremos B = (u^2+uf^2)*(u+uf) segun apuntes ver ppt
   92 :
   93 : real hc=60; //W/m2 k // TEST PARA QUE RESULTE TEMP A LA IZDA CASI LA TEMP AIRE INTERIOR  DE 20 ºC
   94 : real epsilon=1.e-12;
   95 :
   96 : real dt=0.1;
   97 : real T=1.;
   98 :
   99 :
  100 : real den,cap,a;
  101 : den=1; cap=1; // con el objetivo de obtener de forma rapida la solucion estacionaria
  102 :
  103 : a=den*cap;
