 Load: lg_fem lg_mesh lg_mesh3 eigenvalue
    1 : border a0(t=1,0){ x=0; y=t; label=1;}   //contorno de entrada del fluido
    2 : border a1(t=0,2){ x=t; y=0; label=2;}
    3 : border a2(t=0,-0.5){ x=2; y=t; label=2;}
    4 :
    5 : border a3(t=2,20){ x=t; y=-0.5; label=2;}
    6 :
    7 : border a4(t=-0.5,1){ x=20; y=t; label=3;}   //contorno de salida del fluido
    8 :
    9 : border a5(t=1,0){ x=20*t; y=1; label=4;}
   10 :
   11 : // en las paredes solidas se impone que la velocidad es nula (todas las componentes del vector velocidad, aqui 2 lÖD son u,v)
   12 : int n=1;
   13 : mesh Th= buildmesh(a0(3*n)+a1(20*n)+a2(10*n)+a3(150*n)+a4(5*n)+a5(100*n));
   14 :
   15 : /* se recomienda mallar con nro de vertices superior a 8000 nodos, en aplicaciones para capturar bien los remoli lÖnos
   16 :
   17 : el mallado debe ser en teoria , tal que el tamańo de los triangulos (lado mayor de un traiangulo) sean del orden lÖ de cm incluso
   18 : recomendable del orden de milimetros, pero muy alto coste computacional, a veces dos o tres millones de triangul lÖos en aplicaciones industriales */
   19 :
   20 : plot(Th,wait=1);
   21 :
   22 : fespace Vh(Th,P1); // EL METODO QUE USAMOS TIENE LA VENTAJA QUE PODEMOS UTILIZAR P1 TANTO PARA LA VELOCIDAD COMO lÖ LA PRESIÓN
   23 :
   24 : real nu = 0.000016;
   25 :
   26 : // nu es la viscosidad cinematica del fluido, aquí la del aire a 30 şC
   27 :
   28 :
   29 : Vh w,u = 0, v =0, p = 0, q=0;
   30 :
   31 : real area= int2d(Th)(1.);
 *** Warning  The identifier area hide a Global identifier
  // el metodo usa el area del dominio
   32 :
   33 : int iter=0;
   34 :
   35 :
   36 : /* tiempo de simulacion debemos fijarlo sobre 5 s porque L=20m   Vmax es aproximadamente = 4.5 m/s
   37 : (la entrada es 4 m/s pero el vórtice acelera localmente)
   38 : */
   39 :
   40 : real t, tmax=5;
   41 : real dt=0.01; // entre 0.01   y 0.005
   42 :
   43 : for(t=0;t<tmax;t+=dt)
   44 : {
   45 :         iter=iter+1;
   46 :
   47 : Vh uold = u, vold = v, pold=p;
   48 : Vh f=convect([u,v],-dt,uold), g=convect([u,v],-dt,vold);
   49 :
   50 :
   51 :
   52 : solve pb4u(u,w,init=n,solver=LU)   // CALCULA LA COMPONENTE u del vector velocidad
   53 : =int2d(Th)(u*w/dt +nu*(dx(u)*dx(w)+dy(u)*dy(w)))
   54 : -int2d(Th)((f/dt-dx(p))*w)
   55 :
   56 : + on(1,u = 4) + on(2,4,u = 0)+
   57 : on(3,u=f);    // siempre en este metodo en el borde de salida que etiquetaremos siempre con label 3
   58 :
   59 :
   60 : solve pb4v(v,w,init=n,solver=LU)  // CALCULA LA COMPONENTE v del vector velocidad
   61 : = int2d(Th)(v*w/dt +nu*(dx(v)*dx(w)+dy(v)*dy(w)))
   62 : -int2d(Th)((g/dt-dy(p))*w)
   63 :
   64 : +on(1,2,4,v = 0)
   65 : +on(3,v=g);   // siempre en este metodo en el borde de salida que etiquetaremos siempre con label 3
   66 :
   67 : real meandiv = int2d(Th)(dx(u)+dy(v))/area;
   68 :
   69 : solve pb4p(q,w,init=n,solver=LU)= int2d(Th)(dx(q)*dx(w)+dy(q)*dy(w)) // CALCULA la presion
   70 : - int2d(Th)((dx(u)+ dy(v)-meandiv)*w/dt)+ on(3,q=0);
   71 :
   72 : real meanpq = int2d(Th)(pold - q)/area;
   73 :
   74 : p = pold-q-meanpq;      // presion
   75 : u = u + dx(q)*dt;       // u componente en ejex del vector velocidad
   76 : v = v + dy(q)*dt;       // v componente en ejex del vector velocidad
   77 :
   78 : if ( !(iter % 20)) //cada multiplo de 20 imprime el plot de la linea siguiente
   79 : plot([u,v],value=1);
   80 :
   81 : }
