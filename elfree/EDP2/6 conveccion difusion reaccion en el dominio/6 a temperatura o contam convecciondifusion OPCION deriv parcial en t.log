 Load: lg_fem lg_mesh lg_mesh3 eigenvalue
    1 : /* PROBLEMA CONVECCION DIFUSION Y EVOLUTIVO EN EL TIEMPO HACIA LA SOLUCION ESTACIONARIA
    2 :
    3 : aqui el vector velocidad es dato, luego consideramos teoria y aplicaciones con ecuaciones de Navier Stokes para
ücalculo de velocidades */
    4 :
    5 : int n=50;
    6 : int i=0;
    7 :
    8 : border a(t=0,1) {x=t;y=0;label=1;}
    9 : border b(t=0,1) {x=1.;y=t;label=2;}
   10 : border c(t=1,0) {x=t; y=1 ;label=3;}
   11 : border d(t=1,0) {x=0.;y=t;label=4;}
   12 :
   13 : mesh Th = buildmesh(a(n)+b(n)+c(n)+d(n));
   14 : plot (Th, wait=1);
   15 :
   16 : real Cv=1000.;
   17 :
   18 : real dt=0.001,t=0;
   19 : real alpha=1/dt;
   20 :
   21 : fespace Vh(Th,P2);
   22 : Vh T,v,u1,u2,Toldt;
   23 :
   24 : u1=Cv*(y-0.5)*(x-x*x);
   25 : u2=Cv*(0.5-x)*(y-y*y);
   26 : plot([u1,u2],wait=1);
   27 :
   28 : problem convecdif (T,v)=
   29 :
   30 : int2d (Th)  ( T*v/dt)  - int2d(Th)(Toldt*v/dt) // derivada parcial resp tiempo
   31 :
   32 : +int2d(Th) (u1*dx(T)*v+u2*dy(T)*v) // termino nuevo de conveccion
   33 :
   34 : +int2d (Th) ( dx(T)*dx(v)+dy(T)*dy(v) ) // metodo de Euler en estos terminos difusivos
   35 :
   36 :  + on (4,T=0)
   37 :  + on (2,T=1);
   38 :
   39 :
   40 : for (int m=0;m<250;m++)
   41 : {
   42 : t += dt;
   43 : Toldt=T;
   44 : convecdif;
   45 :
   46 : if ( !(m % 10)) //cada multiplo de 10 imprime el plot de la linea siguiente
   47 : plot(T,cmm=" t="+t + ", min=" + T[].min + ", max=" + T[].max,value=1);
   48 :
   49 :
   50 : }
   51 :
   52 :  sizestack + 1024 =4168  ( 3144 )
 
