 Load: lg_fem lg_mesh lg_mesh3 eigenvalue
    1 : /* PROBLEMA CONVECCION DIFUSION Y EVOLUTIVO EN EL TIEMPO HACIA LA SOLUCION ESTACIONARIA
    2 :
    3 : aqui el vector velocidad es dato, luego consideramos teoria y aplicaciones con ecuaciones de Navier Stokes para
calculo de velocidades */
    4 :
    5 : // ejercico 1 fuentes puntuales continuas
    6 :
    7 : // ejercicio 2 fuentes continuas en el tiempo
    8 :
    9 : //
   10 :
   11 : real dt=0.001, t=0;
   12 :
   13 : int n=100;
   14 : int m=0;  // para contar iteraciones luego
   15 :
   16 : border a(t=20,0) {x=-12;y=t;label=1;}
   17 : border b(t=-12,0) {x=t;y=0;label=2;}
   18 : border c(t=0,20) {x=t; y=t ;label=4;}
   19 : border d(t=20,-12) {x=t;y=20;label=3;}
   20 :
   21 : mesh malla = buildmesh(a(n)+b(n)+c(n)+d(n));
   22 : plot(malla, wait=1);
   23 :
   24 :
   25 : real alpha=1/dt;
   26 :
   27 : fespace Vh(malla, P1);
   28 : Vh T,v,u1,u2,k,Toldt;
   29 :
   30 :
   31 : // T es la incognita u
   32 :
   33 : // r e la cte del termino de reaccion
   34 :
   35 : real r=0.3;
   36 :
   37 :
   38 : // velocidad
   39 : u1=10; // Wx
   40 : u2=10; // Wy
   41 :
   42 : k=5;
   43 :
   44 : Toldt=100;
   45 :
   46 : plot([u1, u2], wait=1);
   47 :
   48 :
   49 : //********************** fuentes puntuales
   50 :
   51 : border C2a(t=0, 2*pi) { x=-10+0.0001*cos(t); y = 10+0.0001*sin(t);};
   52 :
   53 : // calculo infinitesimal C = {-10, 10}, fp = 100 W/m2
   54 :
   55 : mesh mallafp1 = buildmesh(C2a(30));  //mallado fp1
   56 :
   57 : fespace Vhfp1(mallafp1, P1);
   58 :
   59 : Vhfp1 fp1;
   60 :
   61 : real AA = 2000; //intensidad fp1
   62 : real BB = 4000; //intensidad fp2
   63 :
   64 :
   65 : real x0, y0;
 *** Warning  The identifier y0 hide a Global identifier
 
   66 : x0=16;
   67 : y0=17;
   68 :
   69 :
   70 :
   71 : border C2p(t=0, 2*pi) { x=x0+0.0001*cos(t); y = y0+0.0001*sin(t);};
   72 :
   73 : // calculo infinitesimal C = {16, 17}, fp = 400 W/m2
   74 :
   75 : mesh mallafp2 = buildmesh(C2p(30));  //mallado fp2
   76 :
   77 : fespace Vhfp2(mallafp2, P2);
   78 : Vhfp2 fp2;
   79 :
   80 : real landa = 2;
   81 :
   82 : fp1 = AA * exp(-landa * ((x+10)^2 + (y - 10)^2));
   83 : fp2 = BB * exp(-landa * ((x-x0)^2 + (y - y0)^2));
   84 :
   85 : real area1 = int2d(mallafp1)(1.);
   86 : real area2 = int2d(mallafp2)(1.);
   87 :
   88 :
   89 :
   90 :
   91 : // comprobacion de calculo infinitesimal
   92 :
   93 : real I1;
   94 : I1 = int2d(mallafp1)(fp1);
   95 : I1 = I1/area1; // I1 == AA
   96 :
   97 : cout << "promedio integral: " << I1 << "\n";
   98 :
   99 : real I2;
  100 : I2 = int2d(mallafp2)(fp2);
  101 : I2 = I2/area2; // I2 == BB
  102 :
  103 :
  104 :
  105 : //*************************dif 1***************************
  106 :
  107 :
  108 :
  109 : problem convecdif1 (T,v)=
  110 :
  111 : int2d (malla)  (T*v / dt)  - int2d(malla)(Toldt*v / dt) // derivada parcial resp tiempo
  112 :
  113 : +int2d(malla) (u1*dx(T)*v+u2*dy(T)*v) // termino nuevo de conveccion
  114 :
  115 : +int2d(malla) (k*dx(T)*dx(v)+k*dy(T)*dy(v) ) // metodo de Euler en estos terminos difusivos
  116 :
  117 : -int1d(malla,2)(10*k*v) -int1d(malla,3)(10*k*v)
  118 :
  119 : +int2d(malla) (r*T*v)
  120 :
  121 : // integrales fuentes puntuales, de vertidos
  122 :
  123 : -int2d(mallafp1)((fp1/area1)*v)
  124 : -int2d(mallafp2)((fp2/area2)*v)
  125 :
  126 :  + on (1,T=100)
  127 :  + on (4,T=200);
  128 :
  129 :
  130 : //************************dif 2****************************
  131 :
  132 : problem convecdif2 (T,v) =
  133 :
  134 : int2d (malla)  (T*v / dt)  - int2d(malla)(Toldt*v / dt) // derivada parcial resp tiempo
  135 :
  136 : +int2d(malla) (u1*dx(T)*v+u2*dy(T)*v) // termino nuevo de conveccion
  137 :
  138 : +int2d(malla) (k*dx(T)*dx(v)+k*dy(T)*dy(v) ) // metodo de Euler en estos terminos difusivos
  139 :
  140 : -int1d(malla,2)(10*k*v) -int1d(malla,3)(10*k*v)
  141 :
  142 : +int2d(malla) (r*T*v)
  143 :
  144 : // dejan de actuar las fuentes puntuales
  145 : //-int2d(mallafp1)((fp1/area1)*v)
  146 : //-int2d(mallafp2)((fp2/area2)*v)
  147 :
  148 :  + on (1,T=100)
  149 :  + on (4,T=200);
  150 :
  151 :
  152 :
  153 :
  154 :
  155 : // show computation
  156 :
  157 : real Tmax=600;
  158 :
  159 : for(t=0;t<Tmax;t+=dt) {
  160 :
  161 :     m=m+1;
  162 :
  163 :
  164 :     if (t < 0.1) {
  165 :         convecdif1;
  166 :     } else {
  167 :         convecdif2;
  168 :     }
  169 :
  170 :     Toldt=T;
  171 :
  172 :     if ( !(m % 3))             //cada multiplo de 10 imprime el plot de la linea siguiente
  173 :     plot(T,cmm=" t="+t + ", min=" + T[].min + ", max=" + T[].max,value=1);
  174 :
  175 : }
