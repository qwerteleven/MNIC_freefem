// caso estacionario

int n=1;
//int m=140;

border a (t=10, 5) {x=t;y=6;label=2;};   // region de aluminio

border b (t=0, 6)  {x=10;y=t;label=1;};  // conveccion de fluido

border c (t=0, 10) {x=t;y=0;label=2;};
border d (t=3, 0) {x=0;y=t;label=2;};

border e (t=0, 5) {x=t;y=3;label=3;}; // interface material
border f (t=3, 6) {x=5;y=t;label=3;};

border g (t=6, 3) {x=0;y=t;label=2;}; // region de cobre
border h (t=5, 0) {x=t;y=6;label=2;};


mesh malla = buildmesh(a(5*n)+b(6*n)+c(10*n)+d(3*n)+e(5*n)+f(3*n)+g(3*n)+h(5*n));
 
plot(malla,wait=1);

fespace Ph(malla,P1);
Ph reg=region;                // a continuacion decimos dos regiones la region cobre y la region aluminio

int cobre =    reg(0.5, 5.5);  // define una region que es de COBRE 
int aluminio = reg(5.5, 5.5);  // define una region que es de ALUMINIO 

plot (reg,fill=1);

real k1,k2;
k1=385.0;         //conductividad termica en el subdominio1     COBRE    (unidades es Watio/(m K)
k2=205.0;		   //conductividad termica en el subdominio2     ALUMINIO (unidades es Watio/(m K)


fespace Vh(malla, P1); // polinomios de interpola de grado uno

/* aconsejable cuando hay cmbio de materiales que implican dvalores numericos muy ditintos de parametros a evaluar en las integrales*/

Vh u,k,v,uu;

real hc=60.; //Coeficiente de convecci�n y temperatura del fluido, p.e. aire, dentro de la circunferencia
real uf=80.; // temperatura aire o agua o fluido dentro del orifico, es decir en contacto con contorno label =2

real hc2=14.; //Coeficiente de convecci�n y temperatura del fluido, p.e. aire, en el exterior del cuadrado
real uf2=20.; // temperatura aire exterior


real epsilon=0.00000001;

problem Calor(u,v) =
int2d(malla) (epsilon*u*v)
+int2d (malla) (k*dx(u)*dx(v)+k*dy(u)*dy(v))

+ int1d(malla,1) (hc*u*v)  - int1d(malla,1) (hc*uf*v) // conveccion fluido

+ int1d(malla,2) (hc2*u*v) - int1d(malla,2) (hc2*uf2*v) // conveccion aire

 + on (1, u=80)
 + on (2, u=20);

 
k = k1*(region==cobre)+k2*(region==aluminio);
 
Calor;
   
x=7.0;
y=3.0;
uu=u(x, y); // temperatura en la interfase cobre-aluminio
cout << " u = " << uu << endl; // plotea en pantalla
plot(u,value=1);
