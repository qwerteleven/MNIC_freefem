  175 : +int2d(malla)   (k*dx(T)*dx(v)+k*dy(T)*dy(v))             // metodo de Euler en estos terminos difusivos
  176 : -int1d(malla,2) (10*k*v) -int1d(malla,3)(10*k*v)
  177 : +int2d(malla)   (r*T*v)
