  142 : //*************************dif 1***************************
  143 :
  144 : // definicion del problema mientras existen las fuentes puntuales
  145 : // siendo A(-10, 10) y B(16, 17)
  146 :
  147 : problem convecdif1 (T,v)=
  148 :
  149 : int2d (malla)   (T*v / dt) - int2d(malla)(Toldt*v / dt)  // derivada parcial resp tiempo
  150 : +int2d(malla)   (u1*dx(T)*v+u2*dy(T)*v)                  // termino nuevo de conveccion
  151 : +int2d(malla)   (k*dx(T)*dx(v)+k*dy(T)*dy(v))            // metodo de Euler en estos terminos difusivos
  152 : -int1d(malla,2) (10*k*v) -int1d(malla,3)(10*k*v)         // flujo respecto a la normal contorno (2, 3) orden 10
  153 : +int2d(malla)   (r*T*v)
  154 :
  155 : // integrales fuentes puntuales, de vertidos
  156 :
  157 : -int2d(mallafp1)((fp1 / area1) * v)
  158 : -int2d(mallafp2)((fp2 / area2) * v)
  159 :
  160 :  + on (1,T=100)    // contorno 1 T = 100
  161 :  + on (4,T=200);   // contorno 4 T = 200
  162 :
  163 :
