   43 : k2=237.0;   // conductividad termica en el subdominio2  ALUMINIO (unidades es Watio/(m K)
   44 :
   45 :
   46 :
   47 : //******************* definicion de los elemtos externos al material **************************
   48 :
   49 : fespace Vh(malla, P1);
   50 :
   51 : Vh told, uold, u,k,v,uu;
   52 :
   53 : real hc=60.; // Coeficiente de conveccion fluido
