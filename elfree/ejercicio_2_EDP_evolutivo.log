   69 :
   70 : + int2d(malla) (u*v / dt) - int2d(malla)(told*v / dt)    // derivada respecto del tiempo
   71 :
   72 : + int2d (malla) (k*dx(u)*dx(v)+k*dy(u)*dy(v))
   73 :
   74 : + int1d(malla,1) (hc*u*v)  - int1d(malla,1) (hc*uf*v)    // conveccion fluido
   75 : + int1d(malla,2) (hc2*u*v) - int1d(malla,2) (hc2*uf2*v); // conveccion aire
   76 :
